<form class="odam-sheet-body">
  <header class="sheet-header">
    <h1>{{actor.name}}</h1>
  </header>

  {{> "systems/odam/templates/actor/parts/details.hbs"}}

  {{> "systems/odam/templates/actor/parts/attributes.hbs"}}

  <section class="sheet-main-grid">
    <section class="sheet-main-left">
      {{> "systems/odam/templates/actor/parts/skills.hbs"}}
    </section>

    <section class="sheet-main-right">
      {{> "systems/odam/templates/actor/parts/derived.hbs"}}

      {{> "systems/odam/templates/actor/parts/pools.hbs"}}

      <section class="sheet-section placeholder-section">
        <h2>Magical</h2>
        <div class="sheet-section-content">
          <p>Controls, Traditions, Remnants, and Practices will go here.</p>
        </div>
      </section>

      <section class="sheet-section placeholder-section">
        <h2>Material</h2>
        <div class="sheet-section-content">
          <p>Possessions and Artifacts will go here.</p>
        </div>
      </section>
    </section>
  </section>
</form>