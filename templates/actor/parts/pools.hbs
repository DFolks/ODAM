<section class="pools">
  <h2>Pools</h2>

  <label>
    Conviction

    <input
      type="number"
      name="system.pools.conviction.value"
      value="{{system.pools.conviction.value}}"
      min="0"
    />

    /

    <input
      type="number"
      name="system.pools.conviction.max"
      value="{{system.pools.conviction.max}}"
      min="0"
    />
  </label>

  <label>
    Nightmare

    <input
      type="number"
      name="system.pools.nightmare"
      value="{{system.pools.nightmare}}"
      min="0"
    />
  </label>

  <label>
    Doubt

    <input
      type="number"
      name="system.pools.doubt"
      value="{{system.pools.doubt}}"
      min="0"
    />
  </label>
</section>